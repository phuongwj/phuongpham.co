---
---

<section id="home" class="max-w-2xl mx-auto mt-20 px-4">
  <div class="rounded-2xl border p-6 stagger-in" style="border-color: var(--c-border); background: var(--c-surface);">
    <div class="flex items-center gap-6">
      <div class="hero-avatar-wrap shrink-0">
        <img
          src="/avatar.jpg"
          alt="Phuong Pham"
          class="hero-avatar"
        />
      </div>

      <div class="flex flex-col gap-2 min-w-0">
        <div class="rotating-subtitle overflow-hidden relative" id="subtitle-container">
          <div id="subtitle-track" class="flex flex-col">
            <p class="text-muted text-xs font-mono uppercase tracking-wider leading-4">3rd Year CS Student @ Dalhousie University</p>
            <p class="text-muted text-xs font-mono uppercase tracking-wider leading-4">Software Engineer</p>
          </div>
        </div>

        <h1 class="text-heading text-3xl font-bold leading-tight">Phuong Pham.</h1>

        <p class="text-body text-[13px] leading-relaxed">
          Building software thoughtfully, with attention to every detail from architecture to implementation.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-avatar-wrap {
    width: 120px;
    height: 120px;
    border-radius: 16px;
    overflow: hidden;
  }
  .hero-avatar {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
</style>

<script>
  const track = document.getElementById('subtitle-track');
  const container = document.getElementById('subtitle-container');
  if (track && container) {
    const items = Array.from(track.children) as HTMLElement[];
    const count = items.length;
    let current = 0;

    container.style.height = items[0].offsetHeight + 'px';

    setInterval(() => {
      current = (current + 1) % count;
      const offset = items.slice(0, current).reduce((sum, el) => sum + el.offsetHeight, 0);
      container.style.transition = 'height 400ms cubic-bezier(0.23, 1, 0.32, 1)';
      container.style.height = items[current].offsetHeight + 'px';
      track.style.transition = 'transform 400ms cubic-bezier(0.23, 1, 0.32, 1)';
      track.style.transform = `translateY(-${offset}px)`;
    }, 5000);
  }
</script>
