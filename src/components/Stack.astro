---
import { stack } from '../utils/data';
---

<section id="stack" class="max-w-2xl mx-auto mt-28 px-4 page-enter">
  <h2 class="text-2xl font-bold text-heading mb-6 tracking-tight">The Toolbox</h2>

  <div class="stagger-in">
    {Object.entries(stack).map(([category, items]) => (
      <div class="mb-5">
        <p class="text-muted text-[11px] font-mono uppercase tracking-wider mb-3">{category}</p>
        <div class="flex flex-wrap gap-2">
          {items.map((tech) => (
            <span class="stack-pill text-body text-xs px-3 py-1 rounded-full border border-border-default bg-transparent cursor-default">
              {tech}
            </span>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>

<style>
  .stack-pill {
    transition: border-color 200ms cubic-bezier(0.23, 1, 0.32, 1),
                color 200ms cubic-bezier(0.23, 1, 0.32, 1),
                transform 200ms cubic-bezier(0.23, 1, 0.32, 1);
  }

  @media (hover: hover) and (pointer: fine) {
    .stack-pill:hover {
      border-color: oklch(0.82 0.008 250);
      color: oklch(0.15 0.01 250);
      transform: translateY(-2px);
    }
  }

  .stack-pill:active {
    transform: scale(0.97);
  }
</style>
