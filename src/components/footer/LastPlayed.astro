---
let track = "";
let artist = "";
let image = "";
let isPlaying = false;

try {
  const res = await fetch(
    `https://ws.audioscrobbler.com/2.0/?method=user.getRecentTracks&user=phuongwj&api_key=${import.meta.env.LASTFM_API_KEY}&format=json&limit=1`
  );
  const json = await res.json();
  const recent = json?.recenttracks?.track?.[0];

  if (recent) {
    track = recent.name || "";
    artist = recent.artist?.["#text"] || "";
    isPlaying = recent["@attr"]?.nowplaying === "true";
    const images = recent.image || [];
    const large = images.find((i: any) => i.size === "large");
    image = large?.["#text"] || "";
  }
} catch (e) {
  console.error("[LastPlayed] Fetch failed:", e);
}

if (!track) {
  track = "Nothing playing";
  artist = "";
}
---

<div class="rounded-2xl border p-4 flex flex-col" style="border-color: var(--c-border); background: var(--c-surface);">
  <div class="flex items-center justify-between mb-3">
    <p class="text-muted text-[11px] font-mono uppercase tracking-wider">last played</p>
    <div class="flex items-center gap-1">
      {isPlaying ? (
        <div class="flex items-end gap-0.5 h-3">
          <span class="eq-bar w-0.75 bg-green-400 rounded-full animate-eq-1" />
          <span class="eq-bar w-0.75 bg-green-400 rounded-full animate-eq-2" />
          <span class="eq-bar w-0.75 bg-green-400 rounded-full animate-eq-3" />
        </div>
      ) : (
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted">
          <path d="M9 18V5l12-2v13" /><circle cx="6" cy="18" r="3" /><circle cx="18" cy="16" r="3" />
        </svg>
      )}
    </div>
  </div>

  <div class="w-3/5 aspect-square rounded-xl overflow-hidden mb-3 mx-auto" style="background: var(--c-surface-hover);">
    {image ? (
      <img
        src={image}
        alt={track}
        class="w-full h-full object-cover"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full flex items-center justify-center">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-muted">
          <path d="M9 18V5l12-2v13" /><circle cx="6" cy="18" r="3" /><circle cx="18" cy="16" r="3" />
        </svg>
      </div>
    )}
  </div>

  <div class="flex flex-col gap-0.5 min-w-0 overflow-hidden items-center text-center">
    <div class="marquee-wrapper">
      <p class="marquee-text text-heading text-sm font-medium whitespace-nowrap">{track}</p>
    </div>
    {artist && (
      <div class="marquee-wrapper">
        <p class="marquee-text text-body text-xs whitespace-nowrap">{artist}</p>
      </div>
    )}
  </div>
</div>

<style>
  .marquee-wrapper {
    overflow: hidden;
  }
  .marquee-wrapper.has-overflow {
    mask-image: linear-gradient(to right, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, black 90%, transparent 100%);
  }

  .marquee-text.scrolling {
    display: inline-block;
    animation: marquee-scroll var(--marquee-duration, 8s) linear infinite;
    padding-right: 2rem;
  }

  @keyframes marquee-scroll {
    0%, 10% { transform: translateX(0); }
    90%, 100% { transform: translateX(calc(-50%)); }
  }

  @keyframes eq-1 {
    0%, 100% { height: 3px; }
    50% { height: 10px; }
  }
  @keyframes eq-2 {
    0%, 100% { height: 6px; }
    50% { height: 12px; }
  }
  @keyframes eq-3 {
    0%, 100% { height: 4px; }
    50% { height: 8px; }
  }
  .animate-eq-1 { animation: eq-1 0.8s ease-in-out infinite; }
  .animate-eq-2 { animation: eq-2 0.6s ease-in-out infinite 0.1s; }
  .animate-eq-3 { animation: eq-3 0.7s ease-in-out infinite 0.2s; }

  @media (prefers-reduced-motion: reduce) {
    .marquee-text.scrolling {
      animation: none;
    }
  }
</style>

<script>
  document.querySelectorAll('.marquee-wrapper').forEach((el) => {
    const text = el.querySelector('.marquee-text') as HTMLElement;
    if (!text) return;
    if (text.scrollWidth > el.clientWidth) {
      el.classList.add('has-overflow');
      const original = text.textContent || '';
      text.textContent = original + '    ' + original + '    ';
      text.classList.add('scrolling');
      const speed = 30;
      const duration = text.scrollWidth / speed;
      text.style.setProperty('--marquee-duration', duration + 's');
    }
  });
</script>
