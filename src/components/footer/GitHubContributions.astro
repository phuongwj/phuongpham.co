---
let weeks: {
    contributionDays: {
        contributionCount: number;
        date: string
    }[]
}[] = [];
let totalContributions = 0;

try {
  const response = await fetch('https://api.github.com/graphql', {
    method: 'POST',
    headers: {
      'Authorization': `Bearer ${import.meta.env.GITHUB_TOKEN}`,
      'Content-Type': 'application/json',
    },
    body: JSON.stringify({
      query: `
        query {
          user(login: "${import.meta.env.GITHUB_USERNAME}") {
            contributionsCollection {
              contributionCalendar {
                totalContributions
                weeks {
                  contributionDays {
                    contributionCount
                    date
                  }
                }
              }
            }
          }
        }
      `
    })
  });

  const json = await response.json();

  const calendar = json?.data?.user?.contributionsCollection?.contributionCalendar;
  if (calendar) {
    weeks = calendar.weeks.slice(-34);
    totalContributions = calendar.totalContributions;
  }
} catch (e) {
  console.error('[GitHubContributions] Fetch failed:', e);
}

function getCellLevel(count: number): number {
  if (count === 0) return 0;
  if (count <= 2) return 1;
  if (count <= 5) return 2;
  return 3;
}
---

<div class="rounded-2xl border p-4 overflow-hidden" style="border-color: var(--c-border); background: var(--c-surface);">
  <div class="flex items-start justify-between mb-3">
    <p class="text-muted text-[11px] font-mono uppercase tracking-wider">github contributions</p>
    <p id="gh-hover-info" class="text-subtle text-[10px] font-mono text-right min-h-3.75 min-w-35">&nbsp;</p>
  </div>

  <div class="flex gap-0.75 overflow-x-auto scrollbar-none">
    {weeks.map((week) => (
      <div class="flex flex-col gap-0.75">
        {week.contributionDays.map((day) => (
          <div
            class={`gh-cell gh-level-${getCellLevel(day.contributionCount)} w-2.5 h-2.5 rounded-xs cursor-default`}
            data-count={day.contributionCount}
            data-date={day.date}
          />
        ))}
      </div>
    ))}
  </div>

  <p class="text-subtle text-[10px] font-mono mt-2">{totalContributions} contributions this year</p>
</div>

<style>
  .gh-level-0 { background-color: var(--c-gh-0); }
  .gh-level-1 { background-color: var(--c-gh-1); }
  .gh-level-2 { background-color: var(--c-gh-2); }
  .gh-level-3 { background-color: var(--c-gh-3); }
</style>

<script>
  const info = document.getElementById('gh-hover-info');

  function formatDate(dateStr: string): string {
    return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    });
  }

  function formatLabel(count: string): string {
    return count === '1' ? '1 contribution' : `${count} contributions`;
  }

  function onCellHover(cell: Element) {
    const count = cell.getAttribute('data-count');
    const date = cell.getAttribute('data-date');
    if (!info || !count || !date) return;

    info.textContent = `${formatLabel(count)} on ${formatDate(date)}`;
  }

  function onCellLeave() {
    if (info) info.textContent = '';
  }

  document.querySelectorAll('.gh-cell').forEach((cell) => {
    cell.addEventListener('mouseenter', () => onCellHover(cell));
    cell.addEventListener('mouseleave', onCellLeave);
  });
</script>
