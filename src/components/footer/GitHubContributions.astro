---
function getCellLevel(count: number): number {
  if (count === 0) return 0;
  if (count <= 2) return 1;
  if (count <= 5) return 2;
  return 3;
}
---

<div class="rounded-2xl border p-4 overflow-hidden" style="border-color: var(--c-border); background: var(--c-surface);">
  <div class="flex items-start justify-between mb-3">
    <p class="text-muted text-[11px] font-mono uppercase tracking-wider">github contributions</p>
    <p id="gh-hover-info" class="text-subtle text-[10px] font-mono text-right min-h-3.75 min-w-35">&nbsp;</p>
  </div>

  <div id="gh-grid" class="flex gap-0.75 overflow-x-auto scrollbar-none">
    <p class="text-muted text-xs font-mono">Loading...</p>
  </div>

  <p class="text-subtle text-[10px] font-mono mt-2" id="gh-total">&nbsp;</p>
</div>

<style is:global>
  .gh-level-0 { background-color: var(--c-gh-0); }
  .gh-level-1 { background-color: var(--c-gh-1); }
  .gh-level-2 { background-color: var(--c-gh-2); }
  .gh-level-3 { background-color: var(--c-gh-3); }
</style>

<script>
  const info = document.getElementById('gh-hover-info');
  const grid = document.getElementById('gh-grid');
  const total = document.getElementById('gh-total');

  function getCellLevel(count: number): number {
    if (count === 0) return 0;
    if (count <= 2) return 1;
    if (count <= 5) return 2;
    return 3;
  }

  function formatDate(dateStr: string): string {
    return new Date(dateStr + 'T00:00:00').toLocaleDateString('en-US', {
      month: 'short',
      day: 'numeric',
      year: 'numeric',
    });
  }

  function formatLabel(count: number): string {
    return count === 1 ? '1 contribution' : `${count} contributions`;
  }

  async function loadContributions() {
    try {
      const res = await fetch('/api/github-contributions');
      const data: any = await res.json();

      if (!grid) return;
      grid.innerHTML = '';

      for (const week of data.weeks) {
        const col = document.createElement('div');
        col.className = 'flex flex-col gap-0.75';

        for (const day of week.contributionDays) {
          const cell = document.createElement('div');
          cell.className = `gh-cell gh-level-${getCellLevel(day.contributionCount)} w-2.5 h-2.5 rounded-xs cursor-default`;
          cell.dataset.count = String(day.contributionCount);
          cell.dataset.date = day.date;

          cell.addEventListener('mouseenter', () => {
            if (info) info.textContent = `${formatLabel(day.contributionCount)} on ${formatDate(day.date)}`;
          });
          cell.addEventListener('mouseleave', () => {
            if (info) info.textContent = '';
          });

          col.appendChild(cell);
        }
        grid.appendChild(col);
      }

      if (total) {
        total.textContent = `${data.totalContributions} contributions this year`;
      }
    } catch (e) {
      if (grid) grid.innerHTML = '<p class="text-muted text-xs font-mono">Failed to load</p>';
    }
  }

  loadContributions();
</script>
