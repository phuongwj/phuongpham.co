---
import Hero from '../components/Hero.astro';
import LinksAbout from '../components/LinksAbout.astro';
import GitHubContributions from '../components/footer/GitHubContributions.astro';
import LastPlayed from '../components/footer/LastPlayed.astro';
import { StackTabs } from '../components/StackTabs';
import { Navbar } from '../components/Navbar';
import Layout from '../layouts/Layout.astro';
---

<Layout>
	<Navbar client:load currentPage="home" />
	<Hero />
	<LinksAbout />
	<section class="max-w-2xl mx-auto px-4 mt-4 pb-40 stagger-in" style="animation-delay: 300ms;">
		<div class="grid grid-cols-1 sm:grid-cols-[1fr_180px] gap-3">
			<GitHubContributions />
			<LastPlayed />
		</div>
		<div class="mt-3">
			<StackTabs client:load />
		</div>
		<p class="text-muted text-xs mt-8">&copy; 2026 Phuong. All rights reserved.</p>
	</section>
</Layout>
